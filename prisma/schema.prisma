// ─── Sub-Agent Module ─────────────────────────────────────────────────────────

model SubAgent {
  id               String                 @id @default(cuid())
  userId           String                 @unique
  user             User                   @relation(fields: [userId], references: [id])
  agencyName       String
  firstName        String?
  lastName         String?
  roleAtAgency     String?
  businessEmail    String?
  primaryDialCode  String?
  agencyCountry    String?
  agencyCity       String?
  phone            String?
  website          String?
  expectedMonthlySubmissions String?
  heardAboutUs     String?
  registrationDocUrl String?
  commissionRate   Float                  @default(50)
  isApproved       Boolean                @default(false)
  approvedAt       DateTime?
  approvedBy       String?                // User ID stored for audit trail
  approvalStatus   SubAgentApprovalStatus @default(PENDING)
  rejectedAt       DateTime?
  rejectedBy       String?                // User ID stored for audit trail
  rejectionReason  String?
  revokedAt        DateTime?
  revokedBy        String?                // User ID stored for audit trail
  revokeReason     String?
  referralCode     String?                @unique
  brandingLogoUrl  String?
  brandingPrimaryColor String?            @default("#1E3A5F")
  brandingContactEmail String?
  brandingContactPhone String?
  brandingWebsite String?
  brandingFacebook String?
  brandingInstagram String?
  brandingLinkedIn String?
  brandingWhatsapp String?
  tier             SubAgentTier?
  tierAchievedAt   DateTime?
  certificateIssuedAt DateTime?
  certificateUrl   String?
  createdAt        DateTime               @default(now())

  // Back-relations
  agreement    SubAgentAgreement?
  leads        Lead[]
  students     Student[]
  referredStudents Student[]              @relation("SubAgentReferral")
  commissions  Commission[]
  invoices     SubAgentInvoice[]
  infoRequests SubAgentInfoRequest[]
  marketingMaterials MarketingMaterial[]
  staffMembers SubAgentStaff[]
  tierCertificates SubAgentTierCertificate[]
  plOffices    PLOffice[]
  plIncomes    PLIncome[]
  plExpenses   PLExpense[]

  @@index([isApproved])
  @@index([approvalStatus])
  @@index([agencyCountry])
  @@index([tier])
}

