  student   Student  @relation("WishlistItemStudent", fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation("WishlistItemCourse", fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
}

// ─── Payments Module ──────────────────────────────────────────────────────────

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([isActive])
}

model StudentInvoice {
  id                    String   @id @default(cuid())
  studentId             String
  student               Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  invoiceNumber         String   @unique
  fileOpeningCharge     Float?
  serviceCharge         Float?
  serviceChargeType     String?
  serviceInstalment1    Float?
  serviceInstalment1Desc String?
  serviceInstalment2    Float?
  serviceInstalment2Desc String?
  ucasFee               Float?
  applicationFee        Float?
  applicationFeeDesc    String?
  applicationFee2       Float?
  applicationFee2Desc   String?
  airportPickupFee      Float?
  airportPickupDesc     String?
  otherDescription      String?
  otherAmount           Float?
  totalAmount           Float
  currency              String   @default("GBP")
  status                String   @default("DUE")
  paymentMethod         String?
  paidAt                DateTime?
  paidBy                String?
  receiptUrl            String?
  receiptFileName       String?
  notes                 String?
  createdBy             String
  createdByRole         String
  createdByName         String
  agencyName            String?
  agencyLogo            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([studentId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model StudentDeclaration {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  declarationText String
  signatureName   String
  signedAt        DateTime
  pdfUrl          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([studentId])
  @@index([applicationId])
  @@index([signedAt])
}

model VerifiedCertificate {
  id               String    @id @default(cuid())
  checklistId      String    @unique
  reference        String    @unique
  publicToken      String    @unique
  studentName      String
  studentEmail     String
  universityName   String
  courseName       String
  destinationCountry String?
  issuedAt         DateTime
  pdfUrl           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([publicToken])
  @@index([reference])
}

// ─── Auth Module ──────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}
