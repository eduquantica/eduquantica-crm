// ─── RBAC Module ─────────────────────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g. "ADMIN", "COUNSELLOR", "MANAGER", "STUDENT", "SUB_AGENT"
  label       String       // e.g. "Admin", "Counsellor"
  isBuiltIn   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  // Back-relations
  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id        String  @id @default(cuid())
  roleId    String
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String  // "leads"|"students"|"applications"|"universities"|"courses"|
                    // "sub-agents"|"communications"|"tasks"|"commissions"|
                    // "visa"|"documents"|"reports"|"settings"
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([roleId, module])
  @@index([roleId])
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  twoFactorEnabled Boolean @default(false)
  twoFactorEnabledAt DateTime?
  twoFactorBackupCodes Json?
  name      String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Back-relations
  subAgent            SubAgent?
  subAgentStaff       SubAgentStaff?
  student             Student?
  assignedLeads       Lead[]                @relation("CounsellorLeads")
  counsellorStudents  Student[]             @relation("CounsellorStudents")
  communications      Communication[]
  tasks               Task[]
  activityLogs        ActivityLog[]
  counsellorApps      Application[]         @relation("CounsellorApplications")
  handledInfoRequests SubAgentInfoRequest[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  chatSessions        ChatSession[]
  mobileUploadSessionsCreated MobileUploadSession[] @relation("MobileUploadSessionCreatedBy")
  confirmedImmigrationAlerts ImmigrationRuleAlert[] @relation("ImmigrationAlertConfirmedBy")
  immigrationChangelogEntries ImmigrationRuleChangelog[] @relation("ImmigrationChangelogConfirmedBy")
  trainingRecords     TrainingRecord[]
  kpiTargets          KpiTarget[]            @relation("KpiTargetStaff")
  kpiResults          KpiResult[]            @relation("KpiResultStaff")
  leadAllocationsReceived LeadAllocation[]   @relation("LeadAllocationAllocatedTo")
  leadAllocationsCreated  LeadAllocation[]   @relation("LeadAllocationAllocatedBy")
  mockInterviewsAssigned  MockInterview[]    @relation("MockInterviewAssignedBy")
  cvProfile            CvProfile?
  verifiedMilestoneDocs ApplicationMilestoneDocument[] @relation("MilestoneVerifiedBy")
  applicationDocumentsUploaded ApplicationDocument[] @relation("ApplicationDocumentUploadedBy")

  @@index([email])
  @@index([roleId])
  @@index([isActive])
}

model Training {
  id               String           @id @default(cuid())
  organisationId   String
  organisationType String
  name             String
  description      String?
  deliveredBy      String?
  trainingDate     DateTime?
  expiryDate       DateTime?
  isRecurring      Boolean          @default(false)
  recurringMonths  Int?
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  records          TrainingRecord[]

  @@index([organisationId])
  @@index([organisationType])
  @@index([trainingDate])
  @@index([expiryDate])
}

model TrainingRecord {
  id             String               @id @default(cuid())
  trainingId     String
  training       Training             @relation(fields: [trainingId], references: [id])
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  completionDate DateTime
  expiryDate     DateTime?
  certificateUrl String?
  notes          String?
  status         TrainingRecordStatus @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([trainingId])
  @@index([userId])
  @@index([expiryDate])
  @@index([status])
}

model KpiTarget {
  id                      String    @id @default(cuid())
  organisationId          String
  organisationType        String
  staffId                 String
  staff                   User      @relation("KpiTargetStaff", fields: [staffId], references: [id])
  period                  KpiPeriod
  periodLabel             String
  startDate               DateTime
  endDate                 DateTime
  targetLeadsContacted    Int       @default(0)
  targetLeadToStudent     Float     @default(0)
  targetStudentToOffer    Float     @default(0)
  targetOfferToDeposit    Float     @default(0)
  targetDepositToVisa     Float     @default(0)
  targetVisaToEnrolled    Float     @default(0)
  targetOverallConversion Float     @default(0)
  targetEnrollments       Int       @default(0)
  setByAdminDefault       Boolean   @default(false)
  overriddenByManager     Boolean   @default(false)
  overriddenByManagerId   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  results                 KpiResult[]

  @@index([organisationId])
  @@index([organisationType])
  @@index([staffId])
  @@index([period])
  @@index([startDate])
  @@index([endDate])
  @@index([setByAdminDefault])
}

model KpiResult {
  id                     String    @id @default(cuid())
  kpiTargetId            String
  kpiTarget              KpiTarget @relation(fields: [kpiTargetId], references: [id])
  staffId                String
  staff                  User      @relation("KpiResultStaff", fields: [staffId], references: [id])
  period                 KpiPeriod
  periodLabel            String
  startDate              DateTime
  endDate                DateTime
  actualLeadsContacted   Int       @default(0)
  actualLeadsConverted   Int       @default(0)
  actualStudentsWithOffer Int      @default(0)
  actualDepositPaid      Int       @default(0)
  actualVisaApplied      Int       @default(0)
  actualEnrolled         Int       @default(0)
  leadContactRate        Float     @default(0)
  leadToStudentRate      Float     @default(0)
  studentToOfferRate     Float     @default(0)
  offerToDepositRate     Float     @default(0)
  depositToVisaRate      Float     @default(0)
  visaToEnrolledRate     Float     @default(0)
  overallConversionRate  Float     @default(0)
  achievementPercentage  Float     @default(0)
  calculatedAt           DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([kpiTargetId])
  @@index([staffId])
  @@index([period])
  @@index([startDate])
  @@index([endDate])
  @@index([calculatedAt])
}

model Lead {
  id                   String     @id @default(cuid())
  firstName            String
  lastName             String
  email                String?
  phone                String?
  source               LeadSource
  status               LeadStatus @default(NEW)
  assignedCounsellorId String?
  assignedCounsellor   User?      @relation("CounsellorLeads", fields: [assignedCounsellorId], references: [id])
  subAgentId           String?
  subAgent             SubAgent?  @relation(fields: [subAgentId], references: [id])
  nationality          String?
  interestedCountry    String?
  interestedLevel      String?
  notes                String?
  chatTranscript       Json?
  campaign             String?
  score                Int        @default(0) // 0-100 lead score
  createdAt            DateTime   @default(now())

  // Back-relations
  communications Communication[]
  tasks          Task[]
  allocations    LeadAllocation[]

  @@index([status])
  @@index([assignedCounsellorId])
  @@index([subAgentId])
  @@index([source])
  @@index([createdAt])
}

model LeadAllocation {
  id            String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id])
  allocatedToId  String
  allocatedTo    User     @relation("LeadAllocationAllocatedTo", fields: [allocatedToId], references: [id])
  allocatedById  String
  allocatedBy    User     @relation("LeadAllocationAllocatedBy", fields: [allocatedById], references: [id])
  allocatedAt    DateTime @default(now())
  notes          String?
  isActive       Boolean  @default(true)

  @@index([leadId])
  @@index([allocatedToId])
  @@index([allocatedById])
  @@index([allocatedAt])
  @@index([isActive])
}

model Student {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  assignedCounsellorId String?
  assignedCounsellor   User?     @relation("CounsellorStudents", fields: [assignedCounsellorId], references: [id])
  firstName            String
  lastName             String
  email                String
  phone                String?
  dateOfBirth          DateTime?
  nationality          String?
  passportNumber       String?
  passportExpiry       DateTime?
  address              String?
  city                 String?
  country              String?
  highestQualification String?
  grades               String?
  englishTestType      String?
  englishTestScore     String?
  workExperience       String?
  hasWorkExperience    Boolean?
  maritalStatus        String?
  emergencyContact     String?
  subAgentId           String?
  subAgent             SubAgent? @relation(fields: [subAgentId], references: [id])
  subAgentStaffId      String?
  subAgentStaff        SubAgentStaff? @relation(fields: [subAgentStaffId], references: [id])
  referredBySubAgentId String?
  referredBySubAgent   SubAgent? @relation("SubAgentReferral", fields: [referredBySubAgentId], references: [id])
  preferredCurrency    String?
  recentlyViewedCourses Json     @default("[]")
  onboardingCompleted  Boolean   @default(false)
  createdAt            DateTime  @default(now())

  // Back-relations
  applications            Application[]
  documents               Document[]
  communications          Communication[]
  tasks                   Task[]
  visaApplications        VisaApplication[]
  postEnrolmentServices   PostEnrolmentService[]
  documentChecklists      DocumentChecklist[]
  mobileUploadSessions    MobileUploadSession[]
  academicProfile         StudentAcademicProfile?
  eligibilityResults      CourseEligibilityResult[]
  eligibilityOverrides    EligibilityOverride[]
  scholarshipApplications StudentScholarshipApplication[]
  testScores              StudentTestScore[]
  workExperiences         WorkExperience[]
  visaRefusals            StudentVisaRefusal[]
  preferences             StudentPreferences?
  wishlistedCourses       StudentWishlist[]
  wishlistItems           WishlistItem[]            @relation("WishlistItemStudent")
  writtenDocuments        StudentDocument[]
  mockInterviews          MockInterview[]
  chatSessions            ChatSession[]
  feePayments             ApplicationFeePayment[]
  cvProfile               CvProfile?
  applicationDocuments    ApplicationDocument[]
  documentRequests        DocumentRequest[]
  invoices                StudentInvoice[]
  declarations            StudentDeclaration[]

  @@index([email])
  @@index([userId])
  @@index([subAgentId])
  @@index([subAgentStaffId])
  @@index([referredBySubAgentId])
  @@index([nationality])
}

model WorkExperience {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  employerName     String
  jobTitle         String
  location         String?
  startDate        DateTime?
  endDate          DateTime?
  isCurrentlyWorking Boolean @default(false)
  responsibilities String?  @db.Text
  orderIndex       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([studentId])
  @@index([studentId, orderIndex])
}

model University {
  id                     String    @id @default(cuid())
  name                   String
  country                String
  city                   String?
  website                String?
  logo                   String?
  type                   UniversityType? @default(PUBLIC)
  qsRanking              Int?
  timesHigherRanking     Int?
  description            String?
  campusPhotos           String[]  @default([])
  foundedYear            Int?
  dliNumber              String?
  applicationFee         Float?
  partnerSince           DateTime?
  currency               String    @default("GBP")
  isActive               Boolean   @default(true)
  contactPerson          String?
  contactEmail           String?

  // Visa info
  postStudyWorkVisa      String?

  // Back-relations
  courses                Course[]
  applications           Application[]
  commissionAgreement    UniversityCommissionAgreement?
  scholarships           Scholarship[]
  marketingMaterials     MarketingMaterial[]
  applicationFeeConfigs  ApplicationFeeConfig[]
  feePayments            ApplicationFeePayment[]

  @@index([country])
  @@index([isActive])
  @@index([type])
}

model Course {
  id                      String      @id @default(cuid())
  universityId            String
  university              University  @relation(fields: [universityId], references: [id])
  name                    String
  level                   CourseLevel
  fieldOfStudy            String?
  duration                String?     // e.g. "3 years", "12 months"
  studyMode              StudyMode   @default(FULL_TIME)
  tuitionFee              Float?      // stored in university currency (Gross Tuition Fee)
  currency                String
  applicationFee          Float?
  tags                    CourseTag[]
  description             String?
  curriculum              String?     // text area for modules/curriculum
  // intakeDatesWithDeadlines is an array of JSON objects
  // [{date: "2024-09", deadline: "2024-08-15"}, ...]
  intakeDatesWithDeadlines Json?
  intakes                 String[]    @default([])  // simple list of intake periods e.g. ["September 2025", "January 2026"]
  totalEnrolledStudents   Int         @default(0)
  completionRate          Float?      // percentage 0-100
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Back-relations
  applications       Application[]
  entryRequirement   CourseEntryRequirement?
  eligibilityResults CourseEligibilityResult[]
  eligibilityOverrides EligibilityOverride[]
  scholarships       Scholarship[]
  wishlistedBy       StudentWishlist[]
  wishlistItems      WishlistItem[]         @relation("WishlistItemCourse")

  @@index([universityId])
  @@index([level])
  @@index([isActive])
  @@index([fieldOfStudy])
  @@index([createdAt])
}

model Application {
  id              String            @id @default(cuid())
  studentId       String
  student         Student           @relation(fields: [studentId], references: [id])
  courseId        String
  course          Course            @relation(fields: [courseId], references: [id])
  universityId    String
  university      University        @relation(fields: [universityId], references: [id])
  counsellorId    String?
  counsellor      User?             @relation("CounsellorApplications", fields: [counsellorId], references: [id])
  subAgentStaffId String?
  subAgentStaff   SubAgentStaff?    @relation(fields: [subAgentStaffId], references: [id])
  status          ApplicationStatus @default(APPLIED)
  intake          String?           // the selected intake period for this application
  visaSubStatus   VisaSubStatus?
  visaRejectionReason String?
  offerConditions String?
  casNumber       String?
  visaApplicationRef String?
  visaVignetteRef String?
  withdrawalReason String?
  submittedToUniversityAt DateTime?
  conditionalOfferAt DateTime?
  unconditionalOfferAt DateTime?
  financeCompleteAt DateTime?
  casIssuedAt     DateTime?
  visaAppliedAt   DateTime?
  visaReceiptDate DateTime?
  enrolledAt      DateTime?
  withdrawnAt     DateTime?
  submittedAt     DateTime?
  offerReceivedAt DateTime?
  notes           String?
  priority        String?
  isUcas          Boolean           @default(false)
  ucasGroupId     String?
  ucasGroupPaymentStatus String?
  createdAt       DateTime          @default(now())

  // Back-relations
  documents       Document[]
  visaApplication VisaApplication?
  postEnrolment   PostEnrolmentService?
  commission      Commission?
  checklist       DocumentChecklist?
  scholarshipApps StudentScholarshipApplication[]
  preCasInterview PreCasInterview?
  visaInterview   VisaInterview?
  writtenDocuments StudentDocument[]
  mockInterviews  MockInterview[]
  feePayments     ApplicationFeePayment[]
  financeRecord   FinanceRecord?
  milestoneDocuments ApplicationMilestoneDocument[]
  applicationDocuments ApplicationDocument[]
  declarations    StudentDeclaration[]

  @@index([studentId])
  @@index([courseId])
  @@index([universityId])
  @@index([counsellorId])
  @@index([subAgentStaffId])
  @@index([status])
  @@index([createdAt])
}

model ApplicationMilestoneDocument {
  id            String                   @id @default(cuid())
  applicationId String
  application   Application              @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  milestone     ApplicationMilestone
  title         String
  description   String?
  required      Boolean                  @default(true)
  status        ApplicationMilestoneStatus @default(MISSING)
  fileName      String?
  fileUrl       String?
  uploadedAt    DateTime?
  verifiedAt    DateTime?
  verifiedById  String?
  verifiedBy    User?                    @relation("MilestoneVerifiedBy", fields: [verifiedById], references: [id])
  notes         String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([applicationId, milestone])
  @@index([applicationId])
  @@index([milestone])
  @@index([status])
}

model ApplicationDocument {
  id             String                   @id @default(cuid())
  applicationId  String
  application    Application              @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  studentId      String?
  student        Student?                 @relation(fields: [studentId], references: [id], onDelete: SetNull)
  milestoneType  ApplicationMilestoneType
  offerType      OfferLetterType?
  visaOutcome    VisaOutcome?
